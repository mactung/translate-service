# Set to "true" if you want to require an API key on every request.
# When true, also set LT_API_KEYS_DB_PATH (LibreTranslate creates a SQLite file)
# and create a key via `ltmanage keys add`.
LT_API_KEYS_ENABLED=false

# Optional: API key the upstream shadowing-speak app will send.
# Generate any random string; add it to LibreTranslate via ltmanage keys add.
TRANSLATE_API_KEY=

# Public URL the upstream app uses to reach this service.
# Example: https://translate.shadowingenglish.com
PUBLIC_URL=
